class EmailService:
    GMAIL_ADDRESS = "omniumverify@gmail.com"
    GMAIL_APP_PASSWORD = "ljql utkt drxx bpbx"
    
    def __init__(self):
        """Initialize Gmail email service."""
        self.sender_email = self.GMAIL_ADDRESS
        self.sender_password = self.GMAIL_APP_PASSWORD
        self.smtp_server = "smtp.gmail.com"
        self.smtp_port = 587
    
    def send_verification_code(self, recipient_email: str, verification_code: str) -> Tuple[bool, str]:
        """
        Send verification code to recipient email via Gmail.
        
        This uses YOUR Gmail account to send emails to YOUR USERS' email addresses.
        
        Args:
            recipient_email: User's email address (where code is sent TO)
            verification_code: 5-digit code to send
            
        Returns:
            Tuple of (success, message)
        """
        try:
            message = MIMEMultipart()
            message["From"] = self.sender_email
            message["To"] = recipient_email  # User's email
            message["Subject"] = "Omnium Trading - Email Verification Code"
            
            body = f"""
Hello,

Your Omnium Trading email verification code is:

{verification_code}

This code will expire in 10 minutes.

If you did not request this code, please ignore this email.

Best regards,
Omnium Trading Team
            """
            
            message.attach(MIMEText(body, "plain"))
            
            # Connect to Gmail SMTP server
            with smtplib.SMTP(self.smtp_server, self.smtp_port) as server:
                server.starttls()  # Secure connection
                server.login(self.sender_email, self.sender_password)
                server.send_message(message)
            
            return True, "Verification code sent to email"
        
        except smtplib.SMTPAuthenticationError as e:
            return False, "Authentication failed. Check Gmail address and app password."
        except smtplib.SMTPException as e:
            return False, f"SMTP error: {str(e)}"
        except Exception as e:
            return False, f"Error sending email: {str(e)}"


class RegistrationSystem:
    """User registration and authentication system with file-based storage and email verification."""
    
    def __init__(self, credentials_file: str = "credentials.json", lockout_file: str = "lockouts.json", 
                 email_service: EmailService = None):
        """
        Initialize the registration system.
        
        Args:
            credentials_file: Path to store user credentials (JSON format)
            lockout_file: Path to store lockout information
            email_service: EmailService instance (uses YOUR Gmail to send emails to users)
        """
        self.credentials_file = credentials_file
        self.lockout_file = lockout_file
        self.email_service = email_service
        self.current_user = None
        self.max_attempts = 3
        self.lockout_duration = 60  # 1 minute in seconds
        self.verification_codes = {}
        self._load_credentials()
        self._load_lockouts()
    
    def _load_credentials(self) -> None:
        """Load existing credentials from file."""
        if os.path.exists(self.credentials_file):
            try:
                with open(self.credentials_file, 'r') as f:
                    self.users = json.load(f)
            except (json.JSONDecodeError, IOError):
                self.users = {}
        else:
            self.users = {}
    
    def _save_credentials(self) -> None:
        """Save credentials to file."""
        with open(self.credentials_file, 'w') as f:
            json.dump(self.users, f, indent=4)
    
    def _load_lockouts(self) -> None:
        """Load existing lockout data from file."""
        if os.path.exists(self.lockout_file):
            try:
                with open(self.lockout_file, 'r') as f:
                    self.lockouts = json.load(f)
            except (json.JSONDecodeError, IOError):
                self.lockouts = {}
        else:
            self.lockouts = {}
    
    def _save_lockouts(self) -> None:
        """Save lockout data to file."""
        with open(self.lockout_file, 'w') as f:
            json.dump(self.lockouts, f, indent=4)
    
    def _initialize_user_lockout(self, username: str) -> None:
        """Initialize lockout tracking for a user."""
        username_lower = username.lower()
        if username_lower not in self.lockouts:
            self.lockouts[username_lower] = {
                "failed_attempts": 0,
                "lockout_until": None
            }
            self._save_lockouts()
    
    def _is_user_locked_out(self, username: str) -> Tuple[bool, int]:
        """Check if user is currently locked out."""
        username_lower = username.lower()
        
        if username_lower not in self.lockouts:
            self._initialize_user_lockout(username)
            return False, 0
        
        lockout_info = self.lockouts[username_lower]
        
        if lockout_info["lockout_until"] is None:
            return False, 0
        
        lockout_time = datetime.fromisoformat(lockout_info["lockout_until"])
        current_time = datetime.now()
        
        if current_time < lockout_time:
            seconds_remaining = int((lockout_time - current_time).total_seconds())
            return True, seconds_remaining
        else:
            lockout_info["failed_attempts"] = 0
            lockout_info["lockout_until"] = None
            self._save_lockouts()
            return False, 0
    
    def _record_failed_attempt(self, username: str) -> None:
        """Record a failed login attempt and apply lockout if necessary."""
        username_lower = username.lower()
        
        if username_lower not in self.lockouts:
            self._initialize_user_lockout(username)
        
        lockout_info = self.lockouts[username_lower]
        lockout_info["failed_attempts"] += 1
        
        if lockout_info["failed_attempts"] >= self.max_attempts:
            lockout_until = datetime.now() + timedelta(seconds=self.lockout_duration)
            lockout_info["lockout_until"] = lockout_until.isoformat()
        
        self._save_lockouts()
    
    def _reset_failed_attempts(self, username: str) -> None:
        """Reset failed attempts counter after successful login."""
        username_lower = username.lower()
        
        if username_lower in self.lockouts:
            self.lockouts[username_lower]["failed_attempts"] = 0
            self.lockouts[username_lower]["lockout_until"] = None
            self._save_lockouts()
    
    def _get_remaining_attempts(self, username: str) -> int:
        """Get remaining login attempts for a user."""
        username_lower = username.lower()
        
        if username_lower not in self.lockouts:
            return self.max_attempts
        
        failed_attempts = self.lockouts[username_lower]["failed_attempts"]
        return max(0, self.max_attempts - failed_attempts)
    
    def _generate_verification_code(self) -> str:
        """Generate a random 5-digit verification code."""
        return ''.join([str(random.randint(0, 9)) for _ in range(5)])
    
    def _email_exists(self, email: str) -> bool:
        """Check if email is already registered."""
        email_lower = email.lower()
        for user_data in self.users.values():
            if "email" in user_data and user_data["email"].lower() == email_lower:
                return True
        return False
    
    def _validate_email(self, email: str) -> Tuple[bool, str]:
        """Validate email format and uniqueness."""
        if "@" not in email or "." not in email:
            return False, "Invalid email format"
        
        if self._email_exists(email):
            return False, "Email already registered"
        
        return True, ""
    
    @staticmethod
    def _hash_password(password: str) -> str:
        """Hash password using SHA-256."""
        return hashlib.sha256(password.encode()).hexdigest()
    
    def _username_exists(self, username: str) -> bool:
        """Check if username already exists."""
        return username.lower() in self.users
    
    def _validate_username(self, username: str) -> Tuple[bool, str]:
        """Validate username requirements."""
        if len(username) < 3:
            return False, "Username must be at least 3 characters long"
        
        if not username.isalnum() and '_' not in username:
            return False, "Username can only contain letters, numbers, and underscores"
        
        if self._username_exists(username):
            return False, "Username already exists"
        
        return True, ""
    
    def _validate_password(self, password: str) -> Tuple[bool, str]:
        """Validate password requirements."""
        if len(password) < 6:
            return False, "Password must be at least 6 characters long"
        
        if not any(char.isupper() for char in password):
            return False, "Password must contain at least one uppercase letter"
        
        if not any(char.isdigit() for char in password):
            return False, "Password must contain at least one digit"
        
        return True, ""
    
    def register(self, username: str, password: str, email: str = None) -> Tuple[bool, str]:
        """Register a new user with optional email."""
        # Validate username
        is_valid, error = self._validate_username(username)
        if not is_valid:
            return False, f"Username validation failed: {error}"
        
        # Validate password
        is_valid, error = self._validate_password(password)
        if not is_valid:
            return False, f"Password validation failed: {error}"
        
        # Validate email if provided
        if email:
            is_valid, error = self._validate_email(email)
            if not is_valid:
                return False, f"Email validation failed: {error}"
        
        # Store user credentials
        user_data = {
            "username": username,
            "password": self._hash_password(password),
            "email_verified": False
        }
        
        if email:
            user_data["email"] = email
        
        self.users[username.lower()] = user_data
        self._save_credentials()
        
        # Initialize lockout tracking for new user
        self._initialize_user_lockout(username)
        
        # Automatically log in after registration
        self.current_user = username
        
        return True, f"Successfully registered and logged in as {username}"
    
    def verify_email_registration(self, username: str) -> Tuple[bool, str]:
        """Send verification code to user's email during registration."""
        username_lower = username.lower()
        
        if username_lower not in self.users:
            return False, "User not found"
        
        user_data = self.users[username_lower]
        
        if "email" not in user_data:
            return False, "No email associated with this account"
        
        if not self.email_service:
            return False, "Email service not configured"
        
        # Generate verification code
        verification_code = self._generate_verification_code()
        
        # Store code with expiry time (10 minutes)
        expiry_time = datetime.now() + timedelta(minutes=10)
        self.verification_codes[username_lower] = {
            "code": verification_code,
            "expiry": expiry_time.isoformat(),
            "attempts": 0
        }
        
        # Send code to email using YOUR Gmail account
        success, message = self.email_service.send_verification_code(
            user_data["email"],
            verification_code
        )
        
        return success, message
    
    def verify_code_registration(self, username: str, code: str) -> Tuple[bool, str]:
        """Verify the code entered during registration."""
        username_lower = username.lower()
        
        if username_lower not in self.verification_codes:
            return False, "No verification code found. Request a new one."
        
        code_data = self.verification_codes[username_lower]
        
        # Check if code has expired
        expiry_time = datetime.fromisoformat(code_data["expiry"])
        if datetime.now() > expiry_time:
            del self.verification_codes[username_lower]
            return False, "Verification code expired. Request a new one."
        
        # Check attempts
        code_data["attempts"] += 1
        if code_data["attempts"] > 3:
            del self.verification_codes[username_lower]
            return False, "Too many incorrect attempts. Request a new code."
        
        # Verify code
        if code == code_data["code"]:
            self.users[username_lower]["email_verified"] = True
            self._save_credentials()
            del self.verification_codes[username_lower]
            return True, "Email verified successfully"
        else:
            remaining = 3 - code_data["attempts"]
            return False, f"Incorrect code. {remaining} attempts remaining."
    
    def verify_code_login(self, username: str, code: str) -> Tuple[bool, str]:
        """Verify the code entered during login."""
        username_lower = username.lower()
        
        if username_lower not in self.verification_codes:
            return False, "No verification code found. Request a new one."
        
        code_data = self.verification_codes[username_lower]
        
        # Check if code has expired
        expiry_time = datetime.fromisoformat(code_data["expiry"])
        if datetime.now() > expiry_time:
            del self.verification_codes[username_lower]
            return False, "Verification code expired. Request a new one."
        
        # Check attempts
        code_data["attempts"] += 1
        if code_data["attempts"] > 3:
            del self.verification_codes[username_lower]
            self._record_failed_attempt(username)
            return False, "Too many incorrect attempts. Login failed."
        
        # Verify code
        if code == code_data["code"]:
            self._reset_failed_attempts(username)
            self.current_user = username
            del self.verification_codes[username_lower]
            return True, f"Successfully logged in as {username}"
        else:
            remaining = 3 - code_data["attempts"]
            return False, f"Incorrect code. {remaining} attempts remaining."
    
    def login(self, username: str, password: str) -> Tuple[bool, str]:
        """Authenticate and login a user with attempt limiting."""
        # Initialize lockout tracking if not exists
        if username.lower() not in self.lockouts:
            self._initialize_user_lockout(username)
        
        # Check if user is locked out
        is_locked, seconds_remaining = self._is_user_locked_out(username)
        if is_locked:
            minutes = seconds_remaining // 60
            seconds = seconds_remaining % 60
            return False, f"Account locked. Try again in {minutes}m {seconds}s"
        
        # Check if username exists
        if not self._username_exists(username):
            self._record_failed_attempt(username)
            remaining = self._get_remaining_attempts(username)
            return False, f"Username not found. {remaining} attempts remaining."
        
        # Check password
        stored_hash = self.users[username.lower()]["password"]
        provided_hash = self._hash_password(password)
        
        if stored_hash != provided_hash:
            self._record_failed_attempt(username)
            remaining = self._get_remaining_attempts(username)
            
            if remaining == 0:
                return False, f"Incorrect password. Account locked for 1 minute."
            else:
                return False, f"Incorrect password. {remaining} attempts remaining."
        
        # Password correct - check if email verification is required
        user_data = self.users[username.lower()]
        
        if "email" in user_data and user_data.get("email_verified", False):
            # Send verification code to email using YOUR Gmail account
            verification_code = self._generate_verification_code()
            expiry_time = datetime.now() + timedelta(minutes=10)
            self.verification_codes[username.lower()] = {
                "code": verification_code,
                "expiry": expiry_time.isoformat(),
                "attempts": 0
            }
            
            if self.email_service:
                success, message = self.email_service.send_verification_code(
                    user_data["email"],
                    verification_code
                )
                if success:
                    return True, "code_required"
                else:
                    return False, "Failed to send verification code to email"
            else:
                return False, "Email service not configured"
        
        # No email verification needed - login successful
        self._reset_failed_attempts(username)
        self.current_user = username
        return True, f"Successfully logged in as {username}"
    
    def logout(self) -> None:
        """Logout the current user."""
        self.current_user = None
    
    def is_logged_in(self) -> bool:
        """Check if a user is currently logged in."""
        return self.current_user is not None
    
    def get_current_user(self) -> str:
        """Get the currently logged-in user."""
        return self.current_user if self.current_user else "None"


class UserInterface:
    """Command-line interface for the registration system."""
    
    def __init__(self, email_service: EmailService = None):
        self.auth = RegistrationSystem("credentials.json", "lockouts.json", email_service)
        self.email_service = email_service
    
    def display_menu(self) -> None:
        """Display main menu options."""
        print("\n" + "=" * 50)
        print("Welcome to Omnium - Trading Software")
        print("=" * 50)
        
        if self.auth.is_logged_in():
            print(f"Logged in as: {self.auth.get_current_user()}")
            print("1. Logout")
            print("2. Access Trading Platform")
            print("3. Exit")
        else:
            print("1. Register")
            print("2. Login")
            print("3. Exit")
        
        print("=" * 50)
    
    def handle_registration(self) -> None:
        """Handle user registration."""
        print("\n--- Registration ---")
        username = input("Enter desired username: ").strip()
        password = input("Enter desired password (Minimum 6 characters, 1 uppercase letter & 1 digit): ").strip()
        
        # Ask if user wants to add email
        add_email = input("Would you like to add an email? (yes/no): ").strip().lower()
        
        email = None
        if add_email in ["yes", "y", "Yes", "YES", "YEs"]:
            email = input("Enter your email address: ").strip()
        
        success, message = self.auth.register(username, password, email)
        print(f"\n{'✓' if success else '✗'} {message}")
        
        # If email was added, verify it
        if success and email:
            print("\n--- Email Verification ---")
            
            # Send verification code using YOUR Gmail account
            success, message = self.auth.verify_email_registration(username)
            print(f"{'✓' if success else '✗'} {message}")
            
            if success:
                max_code_attempts = 3
                for attempt in range(max_code_attempts):
                    code = input(f"Enter the verification code (attempt {attempt + 1}/3): ").strip()
                    
                    success, message = self.auth.verify_code_registration(username, code)
                    print(f"{'✓' if success else '✗'} {message}")
                    
                    if success:
                        break
                    
                    if "Too many" in message:
                        print("Email verification failed. Please register again.")
                        break
    
    def handle_login(self) -> None:
        """Handle user login."""
        print("\n--- Login ---")
        username = input("Enter username: ").strip()
        password = input("Enter password: ").strip()
        
        success, message = self.auth.login(username, password)
        
        # If code verification is required
        if message == "code_required":
            print(f"\n✓ Password verified. Verification code sent to your email.")
            print("--- Code Verification ---")
            
            max_attempts = 3
            for attempt in range(max_attempts):
                code = input(f"Enter the verification code (attempt {attempt + 1}/3): ").strip()
                
                success, message = self.auth.verify_code_login(username, code)
                print(f"{'✓' if success else '✗'} {message}")
                
                if success:
                    break
                
                if "Too many" in message:
                    break
        else:
            print(f"\n{'✓' if success else '✗'} {message}")
    
    def run(self) -> None:
        """Run the main application loop."""
        while True:
            self.display_menu()
            choice = input("Select an option (1-3): ").strip()
            
            if not self.auth.is_logged_in():
                if choice == "1":
                    self.handle_registration()
                elif choice == "2":
                    self.handle_login()
                elif choice == "3":
                    print("\nGoodbye!")
                    break
                else:
                    print("Invalid option. Please try again.")
            else:
                if choice == "1":
                    self.auth.logout()
                    print("Logged out successfully")
                elif choice == "2":
                    print("\n✓ Access Granted - Launching Trading Platform...")
                elif choice == "3":
                    self.auth.logout()
                    print("Goodbye!")
                    break
                else:
                    print("Invalid option. Please try again.")


