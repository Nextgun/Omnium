<UserControl x:Class="Omnium.UI.Dashboard.Panels.DashboardPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Omnium.UI.Dashboard.Panels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Border BorderBrush="#FF2A2A2A"
        BorderThickness="1"
        Background="#FF1A1A1A"
        CornerRadius="10"
        Padding="12">

        <Grid>
            <!-- Define two vertical rows inside the panel -->
            <Grid.RowDefinitions>
                <!-- Header row: height adjusts to content -->
                <RowDefinition Height="Auto"/>

                <!-- Body row: takes remaining available space -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER (Row 0) -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Panel Title"
               FontSize="16"
               FontWeight="SemiBold"
               Foreground="White"/>
            </Grid>

            <!-- BODY (Row 1) -->
            <Border Grid.Row="1"
        Background="#222222"
        CornerRadius="8"
        Padding="10">
                <TextBlock Text="Module content goes here."
               Foreground="#CFCFCF"
               TextWrapping="Wrap"/>
            </Border>
            
        </Grid>

    </Border>
</UserControl>
