<!--
    MainWindow.xaml
    Purpose:
    - Defines the main application shell (global background + layout regions).
    - Overall layout is layered:
        Layer 0 = Global top navigation bar (full width; app-level actions)
        Layer 1 = Global ticker tab bar (full width; instrument/workspace tabs)
        Layer 2 = Main content region (two columns):
            Left  = Sidebar navigation (static menu)
            Right = Panel workspace (modular dashboard panels)
-->

<Window x:Class="Omnium.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Omnium.UI.Dashboard.Panels"
        mc:Ignorable="d"
        Title="Omnium"
        Height="900"
        Width="1600">

    <!-- ==========================================================
         WINDOW BACKGROUND
         Purpose:
         - Defines the global application surface (dark gradient).
         - Intended to unify the visual tone across sidebar + workspace.
         ========================================================== -->
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FF202020" Offset="1"/>
            <GradientStop Color="#FF1A203A" Offset="0"/>
        </LinearGradientBrush>
    </Window.Background>

    <!-- ==========================================================
         WINDOW RESOURCES
         Purpose:
         - Centralizes reusable styles so layout XAML stays clean.
         - Applied via StaticResource to keep styling consistent.
         ========================================================== -->
    <Window.Resources>

        <!-- ======================================================
             SIDEBAR BUTTON STYLE
             Purpose:
             - Standard sidebar menu button styling (card-like).
             - Provides hover + pressed feedback for usability.
             Notes:
             - Uses a custom ControlTemplate so CornerRadius is supported.
             ====================================================== -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <!-- Basic sizing + text layout -->
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Foreground" Value="#E6EAF2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <!-- Custom template (rounded button + hover states) -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="#FF2F3545"
                                BorderBrush="#FF3C445A"
                                BorderThickness="1"
                                CornerRadius="8">

                            <!-- Hosts the button content (text) -->
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <!-- Interaction feedback -->
                        <ControlTemplate.Triggers>

                            <!-- Hover: slightly brighter surface -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF384058"/>
                            </Trigger>

                            <!-- Pressed: slightly darker surface -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF242B3C"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================================================
             SIDEBAR HEADER BUTTON STYLE
             Purpose:
             - Compact version of SidebarButtonStyle used in the ticker tab bar's
               left "sidebar header" area.
             - Designed for Top_1 (3/4 width) and Top_2 (1/4 width).
             Notes:
             - Intentionally smaller height/font to fit the thin ticker bar row.
             ====================================================== -->
        <Style x:Key="SidebarHeaderButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="#E6EAF2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="#FF2F3545"
                                BorderBrush="#FF3C445A"
                                BorderThickness="1"
                                CornerRadius="6">

                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Hover: slightly brighter surface -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF384058"/>
                            </Trigger>

                            <!-- Pressed: slightly darker surface -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF242B3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================================================
             TOP NAV TAB STYLE
             Purpose:
             - App-level navigation buttons (Trade / Account / Orders / etc.).
             - Full-height rectangular hover highlight (no rounded edges).
             Notes:
             - Implemented via custom ControlTemplate to control hover surface.
             - Spacing is applied via Margin so hover does not "fill the gaps".
             ====================================================== -->
        <Style x:Key="TopNavTabStyle" TargetType="Button">
            <!-- Make each button fill the nav bar height -->
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <!-- Keep spacing between buttons WITHOUT making hover fill the gaps -->
            <Setter Property="Margin" Value="0"/>

            <!-- Make the tab area larger (bigger hit target) -->
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Padding" Value="18,0"/>

            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#C9D1E8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <!-- Root grid fills the entire button area -->
                        <Grid>

                            <!-- Full-width highlight background (goes "wall to wall" up to dividers) -->
                            <Border x:Name="Bg"
                                    Background="Transparent"
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Stretch"/>

                            <!-- Button text -->
                            <ContentPresenter x:Name="Content"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

                            <!-- Single divider: RIGHT side only (creates one line between buttons) -->
                            <Border x:Name="RightDivider"
                                    Width="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Stretch"
                                    Background="#22FFFFFF"/>
                        </Grid>

                        <ControlTemplate.Triggers>

                            <!-- Hover: highlight the entire button area -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>

                            <!-- Pressed: slightly stronger highlight -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================================================
     TOP NAV TAB STYLE (WITH LEFT DIVIDER)
     Purpose:
     - Same as TopNavTabStyle but adds a LEFT divider.
     - Used for the first button in a group (TRADE, Account).
     ====================================================== -->
        <Style x:Key="TopNavTabStyleWithLeftDivider"
       TargetType="Button"
       BasedOn="{StaticResource TopNavTabStyle}">

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Grid>

                            <!-- Left divider -->
                            <Border Width="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="#22FFFFFF"/>

                            <!-- Full-width highlight -->
                            <Border x:Name="Bg"
                            Background="Transparent"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch"/>

                            <!-- Button text -->
                            <ContentPresenter
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                            <!-- Right divider -->
                            <Border Width="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Background="#22FFFFFF"/>
                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg"
                                Property="Background"
                                Value="#22FFFFFF"/>
                                <Setter Property="Foreground"
                                Value="#FFFFFF"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg"
                                Property="Background"
                                Value="#33FFFFFF"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ==========================================================
         ROOT LAYOUT GRID
         Purpose:
         - Defines global layout layers:
             Row 0 = Global top navigation bar (full width)
             Row 1 = Global ticker tab bar (full width)
             Row 2 = Main content region (Sidebar + Panel workspace)
         ========================================================== -->
    <Grid>
        <Grid.RowDefinitions>
            <!-- Layer 0: Global navigation bar -->
            <RowDefinition Height="44"/>

            <!-- Layer 1: Global ticker tab bar -->
            <RowDefinition Height="36"/>

            <!-- Layer 2: Main content region -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <!-- Left: Sidebar region -->
            <ColumnDefinition Width="260"/>

            <!-- Right: Panel workspace region -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ======================================================
             LAYER 0: GLOBAL TOP NAVIGATION BAR
             Purpose:
             - Always visible application navigation (app-level actions).
             - OMNIUM title is pinned to top-left of the window.
             Notes:
             - Nav button groups begin after sidebar width so they align with the
               panel workspace column.
             ====================================================== -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                BorderBrush="#2FFFFFFF"
                BorderThickness="0,0,0,1"
                Margin="0,0,0,6">
            <Grid>

                <!-- App title stays pinned to window's top-left -->
                <TextBlock Text="OMNIUM"
                       Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Foreground="#E6EAF2"
                       FontSize="16"
                       FontWeight="SemiBold"/>

                <!-- Nav content begins after sidebar width -->
                <Grid Margin="260,0,0,0">
                    <Grid.ColumnDefinitions>
                        <!-- Left-side nav buttons -->
                        <ColumnDefinition Width="Auto"/>

                        <!-- Spacer pushes right group to the edge -->
                        <ColumnDefinition Width="*"/>

                        <!-- Right group: Account/Orders/P&L -->
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT GROUP: TRADE + placeholders -->
                    <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Left">
                        <Button Style="{StaticResource TopNavTabStyleWithLeftDivider}" Content="TRADE"/>
                        <Button Style="{StaticResource TopNavTabStyle}" Content="button_11"/>
                        <Button Style="{StaticResource TopNavTabStyle}" Content="button_12"/>
                        <Button Style="{StaticResource TopNavTabStyle}" Content="button_13"/>
                        <Button Style="{StaticResource TopNavTabStyle}" Content="button_14"/>
                        <Button Style="{StaticResource TopNavTabStyle}" Content="button_15"/>
                    </StackPanel>

                    <!-- RIGHT GROUP: Account, Orders, P/L -->
                    <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Right"
                            Margin="0,0,16,0">
                        <Button Style="{StaticResource TopNavTabStyleWithLeftDivider}" Content="Account"/>
                        <Button Style="{StaticResource TopNavTabStyle}" Content="Orders"/>

                        <!-- P/L CELL (display-only for now; will later bind to computed P/L) -->
                        <Border Background="Transparent"
                                VerticalAlignment="Stretch"
                                Padding="18,0"
                                MinWidth="150">

                            <TextBlock VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="#8FA1C7"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="P/L: +$1,245.22"/>
                        </Border>
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>

        <!-- ======================================================
             LAYER 1: GLOBAL TICKER TAB BAR
             Purpose:
             - Displays open instrument/workspace tabs (AAPL, TSLA, etc.).
             - Leftmost 260px acts as a "sidebar header" area with quick actions.
             Notes:
             - Currently static (UI only).
             - Will later become dynamic (TabControl bound to workspaces).
             ====================================================== -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Background="Transparent">
            <Grid.ColumnDefinitions>
                <!-- Sidebar header area -->
                <ColumnDefinition Width="260"/>

                <!-- Ticker tabs area -->
                <ColumnDefinition Width="*"/>

                <!-- Right-side static controls -->
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ==================================================
                 SIDEBAR HEADER ACTIONS (Top_1 / Top_2)
                 Purpose:
                 - Quick actions aligned directly above the sidebar column.
                 - Top_1 = 3/4 width; Top_2 = 1/4 width (reference-inspired).
                 ================================================== -->
            <Grid Grid.Column="0" Margin="14,4,14,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource SidebarHeaderButtonStyle}"
                        Content="Top_1"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="1"
                        Style="{StaticResource SidebarHeaderButtonStyle}"
                        Content="Top_2"/>
            </Grid>

            <!-- ==================================================
                 TICKER TABS (start after sidebar width)
                 Notes:
                 - Tabs are placeholders; active/inactive visuals will later be
                   formalized as a styled TabControl.
                 ================================================== -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Stretch">

                <!-- ACTIVE TAB (example) -->
                <Border Background="#1E3A8A"
                        Padding="20,0"
                        VerticalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="AAPL" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock Text="  ×" Foreground="White" Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- INACTIVE TAB (example) -->
                <Border Background="Transparent"
                        Padding="20,0"
                        VerticalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="TSLA" Foreground="#CCCCCC"/>
                        <TextBlock Text="  ×" Foreground="#888888" Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ADD NEW TICKER BUTTON (placeholder) -->
                <Border Background="Transparent"
                        Padding="20,0"
                        VerticalAlignment="Stretch">
                    <TextBlock Text="+"
                               FontSize="16"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Right cluster: placeholder static controls -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Stretch"
                        Margin="0,0,16,0">
                <TextBlock Text="Layout"
                           Foreground="#AAAAAA"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ======================================================
             LAYER 2: LEFT SIDEBAR (below nav/tab bars)
             Purpose:
             - Static app navigation/actions.
             Notes:
             - OMNIUM title was moved to Layer 0 to reduce redundancy.
             ====================================================== -->
        <Border Grid.Row="2"
                Grid.Column="0"
                BorderThickness="0,0,1,0"
                Background="Transparent">

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Sidebar main area -->
                    <RowDefinition Height="*"/>

                    <!-- Bottom status -->
                    <RowDefinition Height="72"/>
                </Grid.RowDefinitions>

                <!-- Sidebar Menu Buttons (placeholders for now) -->
                <StackPanel Grid.Row="0" Margin="14,14">
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="button_1"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="button_2"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="button_3"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="button_4"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="button_5"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="button_6"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="button_7"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="button_8"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="button_9"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="button_10"/>
                </StackPanel>

                <!-- Sidebar Status -->
                <TextBlock Grid.Row="1"
                           Text="Connected"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#9AA6C1"
                           FontSize="12"/>
            </Grid>
        </Border>

        <!-- ======================================================
             LAYER 2: PANEL WORKSPACE AREA (below nav/tab bars)
             Purpose:
             - Primary workspace for modular draggable panels.
             Notes:
             - Margin adds breathing room from window edges and bar rows.
             - Panels will later be hosted in a draggable/grid-snapping surface.
             ====================================================== -->
        <Grid Grid.Row="2" Grid.Column="1" Margin="16,14,16,16">
            <local:DashboardPanelView
                HorizontalAlignment="Left"
                VerticalAlignment="Top"/>
        </Grid>

    </Grid>

</Window>
