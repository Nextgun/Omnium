<!--
    MainWindow.xaml — Omnium Trading Platform
    Layout:
        Row 0 = Search bar + account info
        Row 1 = Main content (sidebar + workspace panels)
        Row 2 = Status bar
    Navigation: sidebar only (top nav bar removed for cleaner layout)
-->

<Window x:Class="Omnium.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="Omnium — Trading Platform"
        Height="900"
        Width="1600">

    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="{StaticResource BgGradientBottom}" Offset="1"/>
            <GradientStop Color="{StaticResource BgGradientTop}" Offset="0"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <!-- Sidebar button style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTitle}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{DynamicResource SidebarBtnBg}" BorderBrush="{DynamicResource SidebarBtnBorder}"
                                BorderThickness="1" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SidebarBtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SidebarBtnPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Panel card style -->
        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- Action button style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{DynamicResource ActionBtnBg}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ActionBtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ActionBtnPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Theme toggle button style -->
        <Style x:Key="ThemeToggleStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="ToolTip" Value="Toggle Light/Dark Mode"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SidebarBtnHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid column header style (shared) -->
        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource GridHeaderFg}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>   <!-- Search bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="26"/>   <!-- Status bar -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ ROW 0: SEARCH BAR + HEADER ═══ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource SearchBarBg}" BorderBrush="{DynamicResource SearchBarBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <TextBlock Grid.Column="0" Text="OMNIUM" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextTitle}" FontSize="18" FontWeight="Bold"/>

                <!-- Search box -->
                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Grid.Column="0" Height="32"
                             Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}" BorderBrush="{DynamicResource InputBorder}"
                             Padding="10,4" FontSize="13" VerticalContentAlignment="Center"
                             KeyDown="SearchBox_KeyDown">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6,0,0,6"/></Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Button Grid.Column="1" Content="Search" Height="32" Padding="14,0"
                            Style="{StaticResource ActionButton}" Click="SearchButton_Click"/>
                </Grid>

                <!-- Account info + user + status + theme toggle -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Account:" Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,0,6,0"/>
                    <TextBlock x:Name="AccountCashText" Text="--" Foreground="{DynamicResource AccentGreen}" FontSize="13" FontWeight="SemiBold" Margin="0,0,20,0"/>
                    <TextBlock x:Name="UserNameText" Text="" Foreground="{DynamicResource AccentBlue}" FontSize="12" Margin="0,0,14,0"/>
                    <Button x:Name="ThemeToggleBtn" Content="&#x2600;" Style="{StaticResource ThemeToggleStyle}"
                            Foreground="{DynamicResource TextTitle}" Click="ThemeToggle_Click" Margin="0,0,14,0"/>
                    <Button x:Name="RefreshBtn" Content="&#x21BB;" Style="{StaticResource ThemeToggleStyle}"
                            Foreground="{DynamicResource TextTitle}" Click="ManualRefresh_Click" ToolTip="Refresh Now" Margin="0,0,14,0"/>
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#EF4444" Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText" Text="Disconnected" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ ROW 1: SIDEBAR ═══ -->
        <Border Grid.Row="1" Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource SidebarBorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Search results -->
                    <RowDefinition Height="*"/>     <!-- Nav -->
                    <RowDefinition Height="Auto"/>  <!-- Status -->
                </Grid.RowDefinitions>

                <!-- Search results list -->
                <StackPanel Grid.Row="0" Margin="10,10,10,0">
                    <TextBlock Text="SEARCH RESULTS" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="4,0,0,6"/>
                    <ListBox x:Name="SearchResultsList" MaxHeight="200"
                             Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}"
                             SelectionChanged="SearchResultsList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <TextBlock Text="{Binding Symbol}" Foreground="{DynamicResource AccentBlue}" FontWeight="SemiBold" Width="60"/>
                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ListItemHover}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ListItemSelected}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>

                <!-- Sidebar navigation -->
                <StackPanel Grid.Row="1" Margin="10,14">
                    <TextBlock Text="NAVIGATION" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="4,0,0,6"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Dashboard" Click="NavDashboard_Click"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Backtest" Click="NavBacktest_Click"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Compare Strategies" Click="NavEvaluate_Click"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Portfolio" Click="NavPortfolio_Click"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Price Chart" Click="NavChart_Click"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Browse Stocks" Click="NavBrowse_Click"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Settings" Click="NavSettings_Click"/>
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="About" Click="NavAbout_Click"/>
                </StackPanel>

                <!-- Bottom status -->
                <TextBlock Grid.Row="2" x:Name="SidebarStatus" Text="Ready"
                           Margin="14,0,0,14" Foreground="{DynamicResource TextSubtle}" FontSize="11"/>
            </Grid>
        </Border>

        <!-- ═══ ROW 1: MAIN WORKSPACE ═══ -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="16,14,16,16">

            <!-- DASHBOARD PANEL (includes trade button + signal) -->
            <Grid x:Name="DashboardPanel" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Dashboard" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Asset info card -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="Selected Asset" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock x:Name="AssetSymbolText" Text="--" Foreground="{DynamicResource TextPrimary}" FontSize="28" FontWeight="Bold"/>
                            <TextBlock x:Name="AssetNameText" Text="Search for a stock to begin" Foreground="{DynamicResource TextSubtle}" FontSize="13"/>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="Price: " Foreground="{DynamicResource TextMuted}" FontSize="15"/>
                                <TextBlock x:Name="AssetPriceText" Text="--" Foreground="{DynamicResource AccentGreen}" FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Trading signal card (with integrated trade button) -->
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelCard}" Margin="8,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Trading Signal" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock x:Name="SignalText" Text="--" Foreground="{DynamicResource TextPrimary}" FontSize="28" FontWeight="Bold"/>
                            <TextBlock x:Name="SignalAlgoText" Text="No algorithm active" Foreground="{DynamicResource TextSubtle}" FontSize="13"/>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="Shares held: " Foreground="{DynamicResource TextMuted}" FontSize="15"/>
                                <TextBlock x:Name="SharesHeldText" Text="0" Foreground="{DynamicResource TextPrimary}" FontSize="15"/>
                            </StackPanel>
                            <Button x:Name="RunTickBtn" Content="Run Algorithm Tick" Style="{StaticResource ActionButton}"
                                    Width="180" HorizontalAlignment="Left" Margin="0,12,0,0" Click="RunTick_Click"/>
                            <TextBlock x:Name="TradeResultText" Text="" Foreground="{DynamicResource AccentGreen}" FontSize="12"
                                       Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Price history card -->
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0,8,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Recent Prices" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,8"/>
                            <ListBox Grid.Row="1" x:Name="PriceHistoryList" Background="Transparent"
                                     BorderThickness="0" Foreground="{DynamicResource TextPrimary}" FontSize="12">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Timestamp}" Foreground="{DynamicResource TextSubtle}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Open, StringFormat='{}{0:F2}'}" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding High, StringFormat='{}{0:F2}'}" Foreground="{DynamicResource AccentGreen}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Low, StringFormat='{}{0:F2}'}" Foreground="{DynamicResource AccentRed}"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Close, StringFormat='{}{0:F2}'}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- Trade history card -->
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelCard}" Margin="8,8,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Recent Trades" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,8"/>
                            <ListBox Grid.Row="1" x:Name="TradeHistoryList" Background="Transparent"
                                     BorderThickness="0" Foreground="{DynamicResource TextPrimary}" FontSize="12">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="{Binding Side}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Side}" Value="BUY">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentGreen}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Side}" Value="SELL">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentRed}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="{Binding Quantity}" Foreground="{DynamicResource TextSecondary}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat='${0:F2}'}" Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Timestamp}" Foreground="{DynamicResource TextSubtle}" FontSize="11"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- BACKTEST PANEL (with configurable days) -->
            <Border x:Name="BacktestPanel" Visibility="Collapsed" Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Backtest" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <TextBlock Grid.Row="1" x:Name="BacktestAssetLabel" Text="No asset selected" Foreground="{DynamicResource TextSubtle}" FontSize="15" Margin="0,0,0,14"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Days:" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="BacktestDaysBox" Text="90" Width="60" Height="32"
                                 Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}" BorderBrush="{DynamicResource InputBorder}"
                                 Padding="8,4" FontSize="13" VerticalContentAlignment="Center">
                            <TextBox.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Button x:Name="RunBacktestBtn" Content="Run Backtest" Style="{StaticResource ActionButton}"
                                Width="140" Margin="10,0,0,0" Click="RunBacktest_Click"/>
                        <Button x:Name="ExportBacktestBtn" Content="Export CSV" Style="{StaticResource ActionButton}"
                                Width="100" Margin="10,0,0,0" Click="ExportBacktest_Click" Visibility="Collapsed"/>
                    </StackPanel>
                    <TextBlock Grid.Row="3" x:Name="BacktestResultText" Text="" Foreground="{DynamicResource TextSecondary}" FontSize="13"
                               Margin="0,4,0,14" TextWrapping="Wrap"/>
                    <DataGrid Grid.Row="5" x:Name="BacktestTradeGrid" AutoGenerateColumns="False"
                              Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                              HeadersVisibility="Column" IsReadOnly="True" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource GridLineBrush}" RowBackground="{DynamicResource GridRowBg}"
                              AlternatingRowBackground="{DynamicResource GridRowAltBg}" Visibility="Collapsed">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeaderStyle}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Bar" Binding="{Binding Bar}" Width="50"/>
                            <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="60"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="80"/>
                            <DataGridTextColumn Header="Shares" Binding="{Binding Shares}" Width="60"/>
                            <DataGridTextColumn Header="Cash" Binding="{Binding Cash}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- EVALUATE PANEL -->
            <Border x:Name="EvaluatePanel" Visibility="Collapsed" Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Strategy Comparison" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <TextBlock Grid.Row="1" x:Name="EvalAssetLabel" Text="No asset selected" Foreground="{DynamicResource TextSubtle}" FontSize="15" Margin="0,0,0,14"/>
                    <Button Grid.Row="2" x:Name="RunEvalBtn" Content="Compare Strategies" Style="{StaticResource ActionButton}"
                            Width="200" HorizontalAlignment="Left" Click="RunEvaluate_Click"/>
                    <TextBlock Grid.Row="3" x:Name="EvalSummaryText" Text="" Foreground="{DynamicResource AccentGreen}" FontSize="14"
                               Margin="0,14,0,10"/>
                    <DataGrid Grid.Row="4" x:Name="EvalResultGrid" AutoGenerateColumns="False"
                              Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                              HeadersVisibility="Column" IsReadOnly="True" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource GridLineBrush}" RowBackground="{DynamicResource GridRowBg}"
                              AlternatingRowBackground="{DynamicResource GridRowAltBg}" Visibility="Collapsed">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeaderStyle}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Strategy" Binding="{Binding Strategy}" Width="120"/>
                            <DataGridTextColumn Header="Return %" Binding="{Binding ReturnPct}" Width="80"/>
                            <DataGridTextColumn Header="Total Value" Binding="{Binding TotalValue}" Width="100"/>
                            <DataGridTextColumn Header="Trades" Binding="{Binding Trades}" Width="60"/>
                            <DataGridTextColumn Header="Buys" Binding="{Binding Buys}" Width="60"/>
                            <DataGridTextColumn Header="Sells" Binding="{Binding Sells}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- PORTFOLIO PANEL -->
            <Border x:Name="PortfolioPanel" Visibility="Collapsed" Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Portfolio Overview" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <TextBlock Grid.Row="1" x:Name="PortfolioSummaryText" Text="" Foreground="{DynamicResource AccentGreen}" FontSize="16" Margin="0,0,0,14"/>
                    <ListBox Grid.Row="2" x:Name="PortfolioList" Background="Transparent"
                             BorderThickness="0" Foreground="{DynamicResource TextPrimary}" FontSize="13">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Symbol}" Foreground="{DynamicResource AccentBlue}" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Shares}" Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Value}" Foreground="{DynamicResource AccentGreen}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding PnL}" Foreground="{DynamicResource TextSubtle}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- CHART PANEL -->
            <Border x:Name="ChartPanel" Visibility="Collapsed" Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Price Chart" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" x:Name="ChartAssetLabel" Text="Select an asset to view its price chart"
                               Foreground="{DynamicResource TextSubtle}" FontSize="14" Margin="0,0,0,10"/>
                    <oxy:PlotView Grid.Row="2" x:Name="PriceChartView" MinHeight="400"
                                  Background="Transparent"/>
                </Grid>
            </Border>

            <!-- BROWSE PANEL (with search filter) -->
            <Border x:Name="BrowsePanel" Visibility="Collapsed" Style="{StaticResource PanelCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Browse Stocks" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="BrowseFilterBox" Width="200" Height="30"
                                 Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}" BorderBrush="{DynamicResource InputBorder}"
                                 Padding="8,4" FontSize="13" VerticalContentAlignment="Center" KeyDown="BrowseFilter_KeyDown">
                            <TextBox.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Button Content="Filter" Style="{StaticResource ActionButton}" Width="70" Margin="6,0,0,0" Click="BrowseFilter_Click"/>
                        <Button Content="Clear" Style="{StaticResource ActionButton}" Width="60" Margin="6,0,0,0" Click="BrowseClearFilter_Click"/>
                    </StackPanel>
                    <TextBlock Grid.Row="2" x:Name="BrowsePageInfo" Text="Loading..." Foreground="{DynamicResource TextMuted}" FontSize="13" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="3" x:Name="BrowseGrid" AutoGenerateColumns="False"
                              Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                              HeadersVisibility="Column" IsReadOnly="True" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource GridLineBrush}" RowBackground="{DynamicResource GridRowBg}"
                              AlternatingRowBackground="{DynamicResource GridRowAltBg}" SelectionMode="Single"
                              MouseDoubleClick="BrowseGrid_DoubleClick">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeaderStyle}"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <Button Content="Previous" Style="{StaticResource ActionButton}" Width="100"
                                Margin="0,0,10,0" Click="BrowsePrev_Click"/>
                        <TextBlock x:Name="BrowsePageNum" Text="Page 1" Foreground="{DynamicResource TextPrimary}" FontSize="14"
                                   VerticalAlignment="Center" Margin="10,0"/>
                        <Button Content="Next" Style="{StaticResource ActionButton}" Width="100"
                                Margin="10,0,0,0" Click="BrowseNext_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- SETTINGS PANEL (merged Account + Config + Algorithm Switch + Theme) -->
            <Border x:Name="SettingsPanel" Visibility="Collapsed" Style="{StaticResource PanelCard}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Settings" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14"/>

                        <!-- Account Section -->
                        <TextBlock Text="ACCOUNT" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Account ID:" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="AccountIdBox" Text="1" Width="60" Height="30"
                                     Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}" BorderBrush="{DynamicResource InputBorder}"
                                     Padding="8,4" FontSize="13" VerticalContentAlignment="Center" TextChanged="AccountId_Changed">
                                <TextBox.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                        <TextBlock x:Name="AccountDetailText" Text="" Foreground="{DynamicResource TextSecondary}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <!-- Algorithm Section -->
                        <TextBlock Text="ALGORITHM" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Active:" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="AlgorithmCombo" Width="140" Height="30" FontSize="13"
                                      Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}" BorderBrush="{DynamicResource InputBorder}">
                                <ComboBoxItem Content="cs" IsSelected="True"/>
                                <ComboBoxItem Content="ml"/>
                            </ComboBox>
                            <Button x:Name="SwitchAlgoBtn" Content="Switch" Style="{StaticResource ActionButton}" Width="80" Margin="8,0,0,0" Click="SwitchAlgorithm_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="AlgoSwitchStatus" Text="" Foreground="{DynamicResource AccentGreen}" FontSize="12" Margin="0,4,0,16"/>

                        <!-- Config Section -->
                        <TextBlock Text="TRADING PARAMETERS" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="36"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Buy Threshold %:" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="BuyThresholdBox" Text="" Height="28"
                                     Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}" BorderBrush="{DynamicResource InputBorder}"
                                     Padding="6,2" FontSize="13" VerticalContentAlignment="Center">
                                <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></TextBox.Resources>
                            </TextBox>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Sell Threshold %:" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="SellThresholdBox" Text="" Height="28"
                                     Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}" BorderBrush="{DynamicResource InputBorder}"
                                     Padding="6,2" FontSize="13" VerticalContentAlignment="Center">
                                <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></TextBox.Resources>
                            </TextBox>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Stop Loss %:" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="StopLossBox" Text="" Height="28"
                                     Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}" BorderBrush="{DynamicResource InputBorder}"
                                     Padding="6,2" FontSize="13" VerticalContentAlignment="Center">
                                <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></TextBox.Resources>
                            </TextBox>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Max Position:" Foreground="{DynamicResource TextMuted}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="MaxPositionBox" Text="" Height="28"
                                     Background="{DynamicResource InputBg}" Foreground="{DynamicResource InputFg}" BorderBrush="{DynamicResource InputBorder}"
                                     Padding="6,2" FontSize="13" VerticalContentAlignment="Center">
                                <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></TextBox.Resources>
                            </TextBox>
                        </Grid>
                        <Button x:Name="SaveConfigBtn" Content="Save Config" Style="{StaticResource ActionButton}"
                                Width="120" HorizontalAlignment="Left" Click="SaveConfig_Click"/>
                        <TextBlock x:Name="ConfigSaveStatus" Text="" Foreground="{DynamicResource AccentGreen}" FontSize="12" Margin="0,6,0,16"/>

                        <!-- Theme Section -->
                        <TextBlock Text="APPEARANCE" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Button Content="Toggle Light/Dark Mode" Style="{StaticResource ActionButton}"
                                Width="200" HorizontalAlignment="Left" Click="ThemeToggle_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ABOUT PANEL -->
            <Border x:Name="AboutPanel" Visibility="Collapsed" Style="{StaticResource PanelCard}">
                <StackPanel>
                    <Image Source="logo.png" Width="80" Height="80" Margin="0,0,0,14" HorizontalAlignment="Left"/>
                    <TextBlock Text="About Omnium" Foreground="{DynamicResource TextPrimary}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="14" TextWrapping="Wrap"
                               Text="Omnium v0.1.0 — Modular Day-Trading Platform&#x0a;&#x0a;Built by QuantumShell for COSC 3370 at TAMUCC.&#x0a;&#x0a;Features:&#x0a;  • Rule-based trading algorithm (mean reversion)&#x0a;  • ML trading algorithm (Linear Regression)&#x0a;  • Runtime algorithm switching&#x0a;  • Real-time market data from Yahoo Finance&#x0a;  • Paper trading with simulated accounts&#x0a;  • Backtesting engine for strategy validation&#x0a;  • Multi-strategy comparison and evaluation&#x0a;  • Interactive price charts (OxyPlot)&#x0a;  • Paginated stock browser&#x0a;  • Email verification for registration&#x0a;&#x0a;Architecture: WPF Desktop → Flask REST API → MariaDB&#x0a;&#x0a;Team: QuantumShell — TAMUCC COSC 3370"/>
                </StackPanel>
            </Border>

        </Grid>

        <!-- ═══ ROW 2: STATUS BAR ═══ -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{DynamicResource StatusBarBg}" BorderBrush="{DynamicResource StatusBarBorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <TextBlock x:Name="StatusBarText" Text="Ready" Foreground="{DynamicResource TextStatusBar}" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="Omnium v0.1.0" Foreground="{DynamicResource TextVersion}" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
