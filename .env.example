# ══════════════════════════════════════════════════════════════
#  Omnium — Environment Variables
#
#  SETUP (one-time, per developer):
#    1. Install MariaDB (https://mariadb.org/download/)
#    2. During install, set a root password (remember it!)
#    3. Copy this file:  cp .env.example .env
#    4. Edit .env and set OMNIUM_DB_PASSWORD to your root password
#    5. Create the database and tables:
#         mysql -u root -p < src/omnium/data/schema.sql
#       Or open a MariaDB shell and run:
#         CREATE DATABASE IF NOT EXISTS omnium_database;
#         USE omnium_database;
#         SOURCE src/omnium/data/schema.sql;
#    6. (Optional) Seed stock data:
#         python -c "from src.omnium.data.seed import seed; seed()"
#
#  IMPORTANT: Never commit .env — it contains your local passwords.
# ══════════════════════════════════════════════════════════════

# ── Database (MariaDB) ──
OMNIUM_DB_HOST=localhost
OMNIUM_DB_PORT=3306
OMNIUM_DB_USER=root
OMNIUM_DB_PASSWORD=your_password_here
OMNIUM_DB_NAME=omnium_database

# ── Email (Gmail SMTP — for email verification, optional) ──
# OMNIUM_EMAIL_ADDRESS=
# OMNIUM_EMAIL_PASSWORD=
