# ══════════════════════════════════════════════════════
#  Omnium — Environment Variables
#  Copy this file to .env and fill in real values.
# ══════════════════════════════════════════════════════

# ── Database ──
OMNIUM_DB_HOST=localhost
OMNIUM_DB_PORT=5432
OMNIUM_DB_NAME=omnium
OMNIUM_DB_USER=omnium
OMNIUM_DB_PASSWORD=omnium

# ── Market Data ──
OMNIUM_DATA_PROVIDER=alpaca
OMNIUM_API_KEY=your_api_key_here
OMNIUM_SYMBOLS=AAPL,MSFT,TSLA

# ── Trading ──
OMNIUM_ACCOUNT_TYPE=paper
OMNIUM_STARTING_CASH=100000
OMNIUM_SLIPPAGE_PCT=0.001
OMNIUM_COMMISSION=0.0
OMNIUM_MAX_POSITION_PCT=0.20
OMNIUM_MIN_CONFIDENCE=0.6
OMNIUM_TRADE_COOLDOWN=60

# ── Algorithm ──
OMNIUM_ACTIVE_ALGO=rule_based
OMNIUM_LOOKBACK=50

# ── Scheduler ──
OMNIUM_MARKET_OPEN=09:30
OMNIUM_MARKET_CLOSE=16:00
OMNIUM_TIMEZONE=US/Eastern

# ── Cache ──
OMNIUM_CACHE_TTL=30
OMNIUM_CACHE_MAX_SIZE=1000
